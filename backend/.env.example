DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/portfolio?schema=public"
PORT=4000
FRONTEND_URL="http://localhost:5173"
# Comma-separated allowed browser origins for CORS
# Example: "http://localhost:5173,https://your-site.surge.sh"
FRONTEND_URLS="http://localhost:5173"
ADMIN_JWT_SECRET="change-this-to-a-long-random-secret"
ADMIN_PASSWORD_HASH=""
# Optional fallback for local dev only (prefer ADMIN_PASSWORD_HASH)
# ADMIN_PASSWORD="your-plain-password"
# Cookie settings (recommended for separate frontend/backend domains in production)
# COOKIE_SAME_SITE should be none for cross-domain auth cookies
COOKIE_SAME_SITE="lax"
COOKIE_SECURE="false"
# Optional: set only when sharing cookies across subdomains
# COOKIE_DOMAIN=".yourdomain.com"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="portfolio-projects"
